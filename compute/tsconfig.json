{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*",
    "../scraper/src/types.ts",
    "../scraper/src/config.ts",
    "../scraper/src/filters.ts",
    "../scraper/src/fetch/activity.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
