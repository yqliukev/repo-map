    {
      "id": "mobile-app",
      "name": "Mobile App",
      "display_name": "Mobile App",
      "summary": "The Mobile App project builds a cross-platform React Native application that enables deep-link activation, push notifications, offline data caching, and a dark-theme UI while keeping bundle sizes and launch times low. We replaced FlatList with FlashList, tuned Hermes GC, introduced SQLite for offline mode, and switched to native deep-link handling to improve performance and reduce bloat. v1.0 was released to iOS and Android in March with sub-second launch, <0.4% crash rate, and strong engagement metrics; v1.1 is now in planning to add full offline support and dark mode.",
      "status": "active",
      "time_range": "Dec 2024 - Mar 2025",
      "keywords": [
