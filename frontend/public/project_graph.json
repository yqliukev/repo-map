    {
      "id": "infra-migration",
      "name": "Infra Migration",
      "display_name": "Infra Migration",
      "summary": "The Infra Migration project modernizes our infrastructure by moving all production services off a legacy EC2 fleet onto AWS EKS, consolidating workloads on a managed Kubernetes platform and upgrading CI/CD pipelines. Using Terraform to provision the EKS cluster and Helm for deployment, we introduced weighted load-balancer routing, integrated AWS Secrets Manager via the External Secrets Operator, and performed RDS and service-mesh migrations with connection-pool isolation. By early March all services\u2014including billing and auth\u2014are running on EKS, production traffic is fully routed, and the original EC2 fleet has been decommissioned, marking the transition complete.",
      "status": "active",
      "time_range": "Dec 2024 - Mar 2025",
      "keywords": [
        "EKS",
        "Kubernetes",
        "Terraform",
        "Helm",
