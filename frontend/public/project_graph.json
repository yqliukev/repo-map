  "nodes": [
    {
      "id": "billing-v2",
      "name": "Billing V2",
      "display_name": "Billing V2",
      "summary": "Billing V2 replaces the legacy flat-rate subscription engine with a usage-based billing platform that tracks per-customer API calls, applies tiered pricing with overage billing, and reconciles proration for mid-cycle upgrades. The solution introduces an invoice_items data model, a Stripe metered-billing integration with robust webhook handling for invoice.paid, payment_failed, and subscription.updated events, a Go-based billing service that consumes usage events via Kafka and aggregates them hourly, and a RESTful billing API for invoice and subscription management. Completed in September-October 2024, the system is fully deployed to staging and production and is accompanied by a post-mortem document that captures the integration patterns and lessons learned.",
      "status": "completed",
      "time_range": "Oct 2024",
      "keywords": [
        "usage-based pricing",
        "Stripe integration",
        "invoice_items",
        "proration logic",
        "billing API",
        "metered billing",
        "subscription tiers",
        "consumer group",
        "usage tracking pipeline",
        "payment_failed webhook"
      ],
