    {
      "id": "design-system-v2",
      "name": "Design System V2",
      "display_name": "Design System V2",
      "summary": "Design System V2 creates a unified visual language across the product by centralizing semantic design tokens (colors, spacing, typography) and delivering a component library that supports dark mode, WCAG AA accessibility, and consistent motion behavior. Phase 1 has shipped ten core components\u2014Button, Typography, TextInput, Select, Checkbox, Radio, Toggle, Badge, Tooltip, and Spinner\u2014via a Storybook instance that consumes the Figma-to-tokens.json pipeline and injects CSS custom properties through a ThemeProvider. As of March 2025 the project remains active, with the first release deployed to design.bsus.dev and the team continuing to refine remaining components and motion token implementations.",
      "status": "active",
      "time_range": "Dec 2024 - Mar 2025",
      "keywords": [
