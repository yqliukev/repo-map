    {
      "id": "onboarding-redesign",
      "name": "Onboarding Redesign",
      "display_name": "Onboarding Redesign",
      "summary": "The Onboarding Redesign project revamps the first-time user experience to cut the 38% dropout between signup and checklist completion by introducing a wizard-based welcome screen, a persistent checklist sidebar, and a guided product tour with anchored tooltips. Built with feature-flagged React components, the new flow uses progressive disclosure, configurable steps, and analytics instrumentation to track activation metrics while allowing staged rollout. By late March the implementation is feature complete and ready for a phased release to a subset of users.",
      "status": "active",
      "time_range": "Jan 2025 - Mar 2025",
